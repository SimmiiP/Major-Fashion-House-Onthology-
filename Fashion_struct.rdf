    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Collection -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Collection">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#designedBy"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Creative_Director"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Creative_Director -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Creative_Director">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Employee"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#employedBy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Fashion_House"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Employee -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Employee"/>
    


    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Fashion_House -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Fashion_House">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#ownedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Parent_Company"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Fashion_Week -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Fashion_Week">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#isHostedAt"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Location"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Location"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Founder -->

