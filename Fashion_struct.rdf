    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Beauty -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Beauty">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Product"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Clothing"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Clothing -->

    <owl:Class rdf:about="http://www.semanticweb.org/simis/ontologies/2026/2/untitled-ontology-5#Clothing">
